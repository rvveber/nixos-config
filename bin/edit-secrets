#!/usr/bin/env bash
set -e

# edit-secrets
# Usage: ./bin/edit-secrets path/to/secrets.yaml

# 1. Determine the key path.
# We prioritize the system's SSH Host Key because that's what we configured in .sops.yaml for this machine.
HOST_KEY_PATH="/etc/ssh/ssh_host_ed25519_key"

if [ -f "$HOST_KEY_PATH" ] && sudo test -r "$HOST_KEY_PATH"; then
    echo "🔑 Using System Host Key: $HOST_KEY_PATH"
    # We use sudo to read the private key, but we run the conversion and sops as the normal user.
    # Note: ssh-to-age reads from stdin if no file is passed, which is safer than temp files.
    export SOPS_AGE_KEY=$(sudo cat "$HOST_KEY_PATH" | nix shell nixpkgs#ssh-to-age -c ssh-to-age -private-key)

else
    echo "⚠️  No SSH Host keys found ($HOST_KEY_PATH) or not readable."
    echo "   Falling back to default SOPS behavior (looking for keys.txt)..."
fi

# Set default secrets file if no argument is provided
if [ -z "$1" ]; then
    # Resolve the repository root relative to this script (bin/edit-secrets)
    REPO_ROOT="$(dirname "$(dirname "$(readlink -f "$0")")")"
    DEFAULT_SECRETS="$REPO_ROOT/src/secrets/secrets.yaml"
    
    echo "📄 No file specified, defaulting to $DEFAULT_SECRETS"
    set -- "$DEFAULT_SECRETS"
fi

# 2. Run SOPS
# We must point SOPS to the config file location since it's no longer at the root
# Requires sops >= 3.8.0 for --config
SECRET_DIR="$(dirname "$1")"
SOPS_CONFIG="$SECRET_DIR/.sops.yaml"

echo "🔓 Opening SOPS editor (using config: $SOPS_CONFIG)..."
nix shell nixpkgs#sops -c sops --config "$SOPS_CONFIG" "$@"
